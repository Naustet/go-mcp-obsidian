# MCP Obsidian Go Configuration

# 1. Authentication
OBSIDIAN_API_KEY=your_api_key_here

# 2. Network
OBSIDIAN_HOST=127.0.0.1
OBSIDIAN_PORT=27124
OBSIDIAN_PROTOCOL=https

# 3. Transport (Set to 'stdio' for Gemini CLI / Claude Desktop)
MCP_TRANSPORT=stdio

# 4. HTTPS Certificate & Security
# If you use HTTPS, choose ONE of these options:
#
# A) Provide a certificate file (Recommended):
# OBSIDIAN_CA_CERT_FILE=/path/to/your/obsidian.crt
#
# B) Provide certificate text:
# OBSIDIAN_CA_CERT_PEM="-----BEGIN CERTIFICATE----- ... ----END CERTIFICATE-----"
#
# C) Skip verification (Easiest for local development):
# Set this to true to ignore certificate errors for self-signed certs.
OBSIDIAN_SKIP_VERIFY=true

# 5. Web Server (Optional)
PORT=8080
